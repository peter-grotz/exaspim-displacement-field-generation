#!/usr/bin/env bash
# Code Ocean entrypoint: FINALIZE — from an S3 transform folder + input volume, produce the four
# named artifacts for a sample:
#   <sampleID>_manual_displacement_field.nrrd
#   <sampleID>_manual_inverse_displacement_field.nrrd
#   <sampleID>_transformed_final.nii.gz
#   <sampleID>_inverted_transform.nii.gz
#
# App Panel parameters (positional — must match the App Builder order top-to-bottom). These are
# AUTHORITATIVE: the capsule reads exactly what you point it at. There is NO /data auto-detection —
# with several samples' assets mounted under /data, guessing would silently read the wrong sample.
#   $1 / TRANSFORMS_S3 : REQUIRED — the transform folder to read, e.g. /data/<sample>_transforms
#                        (a mounted data asset) or an s3:// prefix of the manual Transform*.h5 files
#   $2 / VOLUME_S3     : REQUIRED — /data/<sample>_10um_to_ccf_moved/<sample>_10um_to_ccf_moved.nii.gz
#                        (a mounted data asset) or an s3:// URI
#   $3 / SAMPLE_ID     : optional sample-id override (else inferred from the paths)
set -euo pipefail
cd "$(dirname "$0")"

# CRITICAL for performance: one BLAS thread per worker. Without this, each of the N worker
# processes spawns N BLAS threads (N x N oversubscription) and the CPU thrashes — this alone
# turned a ~2h job into 60h on a 64-core machine. The N *processes* provide the parallelism.
export OMP_NUM_THREADS=1
export OPENBLAS_NUM_THREADS=1
export MKL_NUM_THREADS=1
export NUMEXPR_NUM_THREADS=1
export VECLIB_MAXIMUM_THREADS=1

PY="$(command -v python || command -v python3)"
# Size jobs from the INSTALLED core count (nproc --all), not `nproc`: CO may launch this run
# pinned to 1 CPU, which makes plain `nproc` report 1. The Python entrypoint re-expands CPU
# affinity to all cores (see displacement_field/__init__.py) so the pool actually uses them.
JOBS="${JOBS:-$(nproc --all 2>/dev/null || nproc 2>/dev/null || echo 8)}"

TRANSFORMS="${1:-${TRANSFORMS_S3:-}}"
VOLUME="${2:-${VOLUME_S3:-}}"
SAMPLE="${3:-${SAMPLE_ID:-}}"

echo "transforms : ${TRANSFORMS:-<MISSING>}"
echo "volume     : ${VOLUME:-<MISSING>}"
echo "sample id  : ${SAMPLE:-<infer>}"
echo "jobs       : $JOBS  (nproc=$(nproc 2>/dev/null) all=$(nproc --all 2>/dev/null))"

# Authoritative parameters: a blank required field is an error, never a guess. This prevents
# silently reading a different sample's transforms/volume when multiple assets are mounted.
if [ -z "$TRANSFORMS" ] || [ -z "$VOLUME" ]; then
  echo "ERROR: both parameters are required — set them in the App Panel." >&2
  echo "  transform_folder : e.g. /data/794491_transforms   (or an s3:// prefix of Transform*.h5)" >&2
  echo "  input_volume     : e.g. /data/794491_10um_to_ccf_moved/794491_10um_to_ccf_moved.nii.gz" >&2
  echo "                     (or the matching s3:// URI)" >&2
  exit 1
fi

exec "$PY" -m displacement_field.cli finalize \
    --transforms-dir "$TRANSFORMS" \
    --volume "$VOLUME" \
    ${SAMPLE:+--sample-id "$SAMPLE"} \
    --out-dir /results \
    --jobs "$JOBS"
